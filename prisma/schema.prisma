generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String   @id @default(cuid())
  clerkId          String   @unique
  email            String?
  name             String?
  stripeCustomerId String?
  plan             String   @default("free")
  generationCount  Int      @default(0)
  generationMonth  String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  // Lifecycle email dedup — each set once the corresponding email has been sent.
  activationEmailSentAt    DateTime?
  quotaWarningEmailSentAt  DateTime?
  lastDigestEmailAt        DateTime?
  projects         ContentProject[]
  scheduledPosts   ScheduledPost[]
  brandVoices      BrandVoice[]
  socialAccounts   SocialAccount[]
  performanceInsights PerformanceInsight[]
}

model SocialAccount {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform        String
  accessTokenEnc  String
  refreshTokenEnc String?
  expiresAt       DateTime?
  externalId      String
  externalName    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, platform])
}

model BrandVoice {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String   @default("Ma voix")
  // Raw sample posts the user pasted/uploaded, joined by a separator.
  samples     String
  // AI-extracted style profile (JSON string: tone, structure, vocabulary, etc.).
  profile     String?
  // How many sample posts were provided.
  sampleCount Int      @default(0)
  status      String   @default("ready")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  generations Generation[]

  @@index([userId])
}

model ContentProject {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String           @default("Sans titre")
  originalUrl    String?
  sourceText     String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  generations    Generation[]
  scheduledPosts ScheduledPost[]
}

model Generation {
  id         String   @id @default(cuid())
  projectId  String
  project    ContentProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  platform     String
  content      String?
  tone         String   @default("professionnel")
  status       String   @default("pending")
  brandVoiceId String?
  brandVoice   BrandVoice? @relation(fields: [brandVoiceId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ScheduledPost {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String?
  project     ContentProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  platform    String
  content     String
  tone        String         @default("professionnel")
  scheduledAt DateTime
  status      String         @default("pending")
  publishedAt DateTime?
  error       String?
  // ID of the post on the platform (tweet id / LinkedIn URN), set on publish.
  externalId  String?
  // Engagement metrics — auto-fetched (X) or manually entered (LinkedIn).
  impressions Int?
  likes       Int?
  comments    Int?
  shares      Int?
  metricsAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model PerformanceInsight {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform  String
  // AI-extracted performance profile (JSON: hooks, topics, structure...).
  insight   String
  // How many measured posts the insight was computed from.
  postCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, platform])
}
